APP_ENV=production
APP_URL=
APP_BASE_URL=

# Database driver: supabase or sqlsrv
DB_DRIVER=supabase

# SQL Server, used when DB_DRIVER=sqlsrv
SQLSRV_HOST=160.191.175.132
SQLSRV_PORT=1433
SQLSRV_DATABASE=namthang_magic_ticket
SQLSRV_USERNAME=
SQLSRV_PASSWORD=

# Supabase Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Chỉ dùng ở server-side PHP. Không đưa key này vào JavaScript/frontend.
# Không commit file .env thật lên GitHub public.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Bucket trong Supabase Storage
SUPABASE_STORAGE_BUCKET=magic-ticket-images

ADMIN_USERNAME=
ADMIN_PASSWORD=
